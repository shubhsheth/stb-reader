# Required
STB_PORTAL_URL=http://your-portal-host
STB_MAC=00:1A:79:XX:XX:XX

# Optional STB portal settings
STB_PORTAL_PATH=stalker_portal/c/portal.php
STB_SERIAL=000000000000
STB_LANG=en
STB_TIMEZONE=Europe/London
PORT=8000
LOG_LEVEL=INFO

# Required for /library endpoints
STRM_OUTPUT_DIR=/library
STRM_DATA_DIR=/data

# Base URL reachable by Jellyfin at playback time. Three options:
#   Docker service name (same Compose network):
#     STRM_SERVER_BASE_URL=http://stb-reader:8000
#   Host LAN IP (direct play on LAN):
#     STRM_SERVER_BASE_URL=http://192.168.1.x:8000
#   Reverse proxy hostname (remote access):
#     STRM_SERVER_BASE_URL=https://stb.yourdomain.com
STRM_SERVER_BASE_URL=http://stb-reader:8000

# Portal content sync
# How often to re-sync all portal content (hours). Set to 0 to disable scheduled syncs.
# A sync always runs on startup if the cache is empty.
VOD_SYNC_INTERVAL_HOURS=24

# Delay between portal HTTP requests during sync (milliseconds).
# Increase if the portal rate-limits or becomes unresponsive during sync.
VOD_SYNC_REQUEST_DELAY_MS=250

# Limit the number of content pages fetched per sync. 0 = no limit (full sync).
# Set to a small number (e.g. 2) to test sync without pulling the full catalogue.
VOD_SYNC_MAX_PAGES=0
