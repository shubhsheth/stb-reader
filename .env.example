# Required
STB_PORTAL_URL=http://your-portal-host
STB_MAC=00:1A:79:XX:XX:XX

# Optional
STB_PORTAL_PATH=stalker_portal/c/portal.php
STB_SERIAL=000000000000
STB_LANG=en
STB_TIMEZONE=Europe/London
PORT=8000

# Library / .strm generator (required for /library endpoints)
STRM_OUTPUT_DIR=/library

# Base URL reachable by Jellyfin at playback time. Three options:
#   Docker service name (transcoded playback, same Compose network):
#     STRM_SERVER_BASE_URL=http://stb-reader:8000
#   Host LAN IP (direct play on LAN):
#     STRM_SERVER_BASE_URL=http://192.168.1.x:8000
#   Reverse proxy hostname (remote access, all playback modes):
#     STRM_SERVER_BASE_URL=https://stb.yourdomain.com
STRM_SERVER_BASE_URL=http://stb-reader:8000

STRM_DATA_DIR=/data
STRM_SYNC_INTERVAL_HOURS=6
